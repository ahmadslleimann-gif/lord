# LORD — never cache the product catalog so dashboard publishes show up instantly.
# Everything else (images, css) caches normally.
<IfModule mod_headers.c>
  <Files "products-data.js">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>
</IfModule>
